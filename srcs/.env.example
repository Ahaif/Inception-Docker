# Replace 'yourlogin' with your actual 42 login everywhere below
LOGIN=yourlogin
DOMAIN_NAME=yourlogin.42.fr
HOST_DATA=/home/yourlogin/data
SECRETS_DIR=/home/yourlogin/secrets

# Non-sensitive database settings (passwords live in SECRETS_DIR)
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user

# WordPress admin account
# IMPORTANT: admin_user must NOT contain 'admin' or 'Admin' (evaluation requirement)
WP_ADMIN_USER=webmaster
WP_ADMIN_EMAIL=webmaster@yourlogin.42.fr
